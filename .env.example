# MAX Bot Token
MAX_BOT_TOKEN=your_max_bot_token_here

# Webhook secret for signature verification (optional but recommended)
WEBHOOK_SECRET=your_webhook_secret_here

# Port for Express server
PORT=3000

# amoCRM settings
AMOCRM_DOMAIN=yourdomain.amocrm.ru
AMOCRM_CLIENT_ID=your_client_id
AMOCRM_CLIENT_SECRET=your_client_secret
AMOCRM_REDIRECT_URI=https://your-server.com/oauth
AMOCRM_ACCESS_TOKEN=your_access_token
AMOCRM_REFRESH_TOKEN=your_refresh_token

# Pipeline settings (amoCRM)
AMOCRM_PIPELINE_ID=0
AMOCRM_STAGE_ID=0

# Company info (shown in final message)
COMPANY_PHONE=+79994449897
COMPANY_WORK_HOURS=9:00-20:00
